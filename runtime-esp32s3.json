{
  "dt:&cpu0:compatible": "espressif,xtensa-lx7",
  "dt:&cpu0:clock-frequency": "240_000_000",

  "runtime":
  {
    "languages": ["ada", "c"],
    "common_required_switches": ["-mlongcalls"],
    "linker_required_switches": ["-nostartfiles", "-nolibc"],
    "system":
    {
      "parameters":
      {
        "Suppress_Standard_Library": false
      },
      "restrictions":
      {
        "No_Finalization": false,
        "No_Exception_Propagation": false,
        "No_Implicit_Dynamic_Code": false
      }
    },
    "files":
