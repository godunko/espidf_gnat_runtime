      "s-textio.adb": { "crate": "espidf_runtime", "path": "source/s-textio.adb" },

      //  Files below are necessary for "embedded"
      "a-nllefu.ads": { "crate": "bb_runtimes", "path": "gnat_rts_sources/include/rts-sources/math/long_long_64bit/a-nllefu.ads" },

      "a-calclo.adb": { "crate": "espidf_runtime", "path": "source/a-calclo.adb" },
      "a-reatim.adb": { "crate": "bb_runtimes", "path": "gnat_rts_sources/include/rts-sources/gnarl/common/a-reatim.adb" },
      "a-reatim.ads": { "crate": "bb_runtimes", "path": "gnat_rts_sources/include/rts-sources/gnarl/common/a-reatim.ads" },
      "s-excmac.adb": { "crate": "bb_runtimes", "path": "gnat_rts_sources/include/rts-sources/full/zcx-dw2/s-excmac.adb" },
      "s-excmac.ads": { "crate": "bb_runtimes", "path": "gnat_rts_sources/include/rts-sources/full/zcx-dw2/s-excmac.ads" },
